{
	"name": "moseland/bearded-media",
	"description": "AI Media Tools for WordPress. Features client-side optimization, vision-based auto-tagging, and generative editing.",
	"version": "1.0.0",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Matthew Oseland",
			"email": "moseland@gmail.com"
		}
	],
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"phpstan/extension-installer": true,
			"pestphp/pest-plugin": true
		}
	},
	"require": {
		"php": ">=8.2"
	},
	"require-dev": {
		"phpstan/phpstan": "^1.10",
		"szepeviktor/phpstan-wordpress": "^1.3",
		"wp-coding-standards/wpcs": "^3.0",
		"phpunit/phpunit": "^10.0",
		"pestphp/pest": "^2.0"
	},
	"autoload": {
		"psr-4": {
			"BeardedMedia\\": "includes/"
		}
	},
	"scripts": {
		"analyze": "vendor/bin/phpstan analyze --memory-limit=-1",
		"format": "vendor/bin/phpcs",
		"test": "vendor/bin/pest"
	}
}